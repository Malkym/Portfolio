{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portfolio ultra-configurable — front public + admin caché, conçu pour durer.",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "vue-tsc --noEmit && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "preview": "npm run build && npm run start",
    "seed": "tsx scripts/seed.ts",
    "themes": "tsx scripts/generate-themes.ts",
    "backup": "tsx scripts/backup.ts",
    "hash": "tsx scripts/hash-password.ts",
    "lint": "eslint . --ext .ts,.vue --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/vue": "^1.25.0",
    "@vueuse/core": "^11.3.0",
    "@vueuse/head": "^2.0.0",
    "@vueuse/motion": "^2.2.6",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dompurify": "^3.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
