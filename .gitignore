node_modules/
dist/

# Secrets : ne doivent JAMAIS être publiés.
.env
.env.local
.env.*.local

# Données du site. Elles vous appartiennent et n'ont rien à faire sur GitHub :
# la base contient vos contenus, vos commentaires reçus et vos statistiques.
data/*.db
data/*.db-shm
data/*.db-wal
data/uploads/
data/backups/
# data/portfolio-data.json est VOLONTAIREMENT versionné : c'est le contenu
# du portfolio, rechargé au démarrage quand la base est vierge. Sans lui, un
# hébergeur sans disque persistant afficherait un site vide à chaque
# redémarrage. Il ne contient que ce qui est déjà public sur le site.

*.log
.DS_Store
.vscode/
.idea/
coverage/
