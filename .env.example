# ---------------------------------------------------------------
# Configuration locale. NE JAMAIS committer ce fichier.
# Régénérez vos propres secrets avec : npm run hash -- "motDePasse"
# ---------------------------------------------------------------

PORT=4400
NODE_ENV=development

# Chemin d'accès à l'administration. Changez-le : c'est votre porte d'entrée.
ADMIN_PATH=/admin-secret
VITE_ADMIN_PATH=/admin-secret

# Générez-le avec : npm run hash -- "votreMotDePasse"
ADMIN_PASSWORD_HASH=

JWT_SECRET=
VISITOR_SALT=

# Question secrète (2FA simple). Laissez vide pour désactiver.
ADMIN_SECRET_QUESTION=
ADMIN_SECRET_ANSWER=

DATABASE_PATH=./data/portfolio.db
